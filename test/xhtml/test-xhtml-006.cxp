    <html>
      <cxp:xhtml>
        <cxp:xsl name="CgiPieUi.xsl">
          <cxp:variable name="str_path" select="''"/>
          <cxp:variable name="flag_header" select="true()"/>
        </cxp:xsl>
      </cxp:xhtml>
      <body>
        <div id="ui">
          <cxp:xhtml>
            <div id="content">
              <h1>TEST</h1>
            </div>
          </cxp:xhtml>
        </div>
      </body>
    </html>
  </cxp:xhtml>
</cxp:make>
