  <cxp:plain name="result/test-plain-cache-002-001.txt">
    <cxp:plain name="TEST-0b"/>
  </cxp:plain>
  <cxp:plain cacheas="TEST-0b">
    <cxp:plain name="Length_1024.txt"/>
  </cxp:plain>
  <cxp:plain name="result/test-plain-cache-002-002.txt">
    <cxp:plain name="TEST-0b"/>
  </cxp:plain>
</cxp:make>
