IF (HINT_DIR_INCLUDE)
  find_path(LIBXSLT_INCLUDE_DIR NAMES "xslt.h" HINTS ${HINT_DIR_INCLUDE} PATH_SUFFIXES "libxslt" NO_CMAKE_FIND_ROOT_PATH)
  #SET(LIBXSLT_INCLUDE_DIR ${HINT_DIR_INCLUDE} CACHE PATH "include files of libxslt")
  #cmake_path(GET _LIBXSLT_INCLUDE_DIR PARENT_PATH LIBXSLT_INCLUDE_DIR)
  #message(ERROR " LIBXSLT_INCLUDE_DIR=${LIBXSLT_INCLUDE_DIR}")
  #SET(LIBXSLT_INCLUDE_DIR ${LIBXSLT_INCLUDE_DIR} CACHE PATH "" FORCE)
  find_library(LIBXSLT_LIBRARY_DEBUG NAMES "xslt" HINTS ${HINT_DIR_LIBD} NO_CMAKE_FIND_ROOT_PATH)
  find_library(LIBXSLT_LIBRARY_RELEASE NAMES "xslt" HINTS ${HINT_DIR_LIB} NO_CMAKE_FIND_ROOT_PATH)

  #SET(LIBXSLT_EXSLT_INCLUDE_DIR ${HINT_DIR_INCLUDE} CACHE PATH "include files of libexslt")
  #find_path(_LIBXSLT_EXSLT_INCLUDE_DIR NAMES "exslt.h" HINTS "${HINT_DIR_INCLUDE}/libexslt") 
  #cmake_path(GET _LIBXSLT_EXSLT_INCLUDE_DIR PARENT_PATH LIBXSLT_EXSLT_INCLUDE_DIR)
  #message(ERROR " LIBXSLT_EXSLT_INCLUDE_DIR=${LIBXSLT_EXSLT_INCLUDE_DIR}")
  #SET(LIBXSLT_EXSLT_INCLUDE_DIR ${LIBXSLT_INCLUDE_DIR} CACHE PATH "" FORCE)
  find_library(LIBXSLT_EXSLT_LIBRARY_DEBUG NAMES "exslt" HINTS ${HINT_DIR_LIBD} NO_CMAKE_FIND_ROOT_PATH)
  find_library(LIBXSLT_EXSLT_LIBRARY_RELEASE NAMES "exslt" HINTS ${HINT_DIR_LIB} NO_CMAKE_FIND_ROOT_PATH)

  find_program(LIBXSLT_XSLTPROC_EXECUTABLE NAMES "xsltproc" HINTS ${HINT_DIR} PATH_SUFFIXES "tools/libxslt" NO_CMAKE_FIND_ROOT_PATH)
ENDIF ()

IF (LIBXSLT_INCLUDE_DIR AND LIBXSLT_LIBRARY_DEBUG)
  SET(LIBXSLT_LIBRARIES ${LIBXSLT_LIBRARY_DEBUG})
  SET(LIBXSLT_EXSLT_LIBRARIES ${LIBXSLT_EXSLT_LIBRARY_DEBUG})
  MESSAGE(STATUS "Found debug libxslt: ${LIBXSLT_LIBRARIES}")
  INCLUDE_DIRECTORIES(${LIBXSLT_INCLUDE_DIR})
  #add_compile_definitions(${LIBXSLT_DEFINITIONS})
  IF ("${LIBXSLT_LIBRARY}" MATCHES ".+static.*\\.lib" OR "${LIBXSLT_LIBRARY}" MATCHES ".+\\.a")
    add_compile_definitions(LIBXSLT_STATIC)
  ENDIF ()
ELSEIF (LIBXSLT_INCLUDE_DIR AND LIBXSLT_LIBRARY_RELEASE)
  SET(LIBXSLT_LIBRARIES ${LIBXSLT_LIBRARY_RELEASE})
  SET(LIBXSLT_EXSLT_LIBRARIES ${LIBXSLT_EXSLT_LIBRARY_RELEASE})
  MESSAGE(STATUS "Found libxslt: ${LIBXSLT_LIBRARIES}")
  INCLUDE_DIRECTORIES(${LIBXSLT_INCLUDE_DIR})
  #add_compile_definitions(${LIBXSLT_DEFINITIONS})
  IF ("${LIBXSLT_LIBRARY}" MATCHES ".+static.*\\.lib" OR "${LIBXSLT_LIBRARY}" MATCHES ".+\\.a")
    add_compile_definitions(LIBXSLT_STATIC)
  ENDIF ()
ELSE()
  FIND_PACKAGE( LibXslt )
ENDIF ()
