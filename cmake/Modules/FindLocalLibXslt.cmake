################################################################################
#
# libxslt
#

IF (HINT_DIR_INCLUDE)
  find_path(LIBXSLT_INCLUDE_DIR NAMES "xslt.h" HINTS ${HINT_DIR_INCLUDE} PATH_SUFFIXES "libxslt" NO_CMAKE_FIND_ROOT_PATH)
  find_library(LIBXSLT_LIBRARY_DEBUG NAMES "xslt" "libxslt" HINTS ${HINT_DIR_LIBD} NO_CMAKE_FIND_ROOT_PATH)
  find_library(LIBXSLT_LIBRARY_RELEASE NAMES "xslt" "libxslt" HINTS ${HINT_DIR_LIB} NO_CMAKE_FIND_ROOT_PATH)
  find_library(LIBXSLT_EXSLT_LIBRARY_DEBUG NAMES "exslt" "libexslt" HINTS ${HINT_DIR_LIBD} NO_CMAKE_FIND_ROOT_PATH)
  find_library(LIBXSLT_EXSLT_LIBRARY_RELEASE NAMES "exslt" "libexslt" HINTS ${HINT_DIR_LIB} NO_CMAKE_FIND_ROOT_PATH)
  find_program(LIBXSLT_XSLTPROC_EXECUTABLE NAMES "xsltproc" HINTS ${HINT_DIR} PATH_SUFFIXES "tools/libxslt" NO_CMAKE_FIND_ROOT_PATH)
ENDIF ()

IF (LIBXSLT_INCLUDE_DIR AND LIBXSLT_LIBRARY_DEBUG)
  SET(LIBXSLT_LIBRARIES ${LIBXSLT_LIBRARY_DEBUG})
  SET(LIBXSLT_EXSLT_LIBRARIES ${LIBXSLT_EXSLT_LIBRARY_DEBUG})
  MESSAGE(STATUS "Found debug libxslt: ${LIBXSLT_LIBRARIES}")
  INCLUDE_DIRECTORIES(${LIBXSLT_INCLUDE_DIR})
  #add_compile_definitions(${LIBXSLT_DEFINITIONS})
  IF ("${LIBXSLT_LIBRARY}" MATCHES ".+static.*\\.lib" OR "${LIBXSLT_LIBRARY}" MATCHES ".+\\.a")
    add_compile_definitions(LIBXSLT_STATIC)
  ENDIF ()
ELSEIF (LIBXSLT_INCLUDE_DIR AND LIBXSLT_LIBRARY_RELEASE)
  SET(LIBXSLT_LIBRARIES ${LIBXSLT_LIBRARY_RELEASE})
  SET(LIBXSLT_EXSLT_LIBRARIES ${LIBXSLT_EXSLT_LIBRARY_RELEASE})
  MESSAGE(STATUS "Found libxslt: ${LIBXSLT_LIBRARIES}")
  INCLUDE_DIRECTORIES(${LIBXSLT_INCLUDE_DIR})
  #add_compile_definitions(${LIBXSLT_DEFINITIONS})
  IF ("${LIBXSLT_LIBRARIES}" MATCHES ".+static.*\\.lib" OR "${LIBXSLT_LIBRARIES}" MATCHES ".+\\.a")
    add_compile_definitions(LIBXSLT_STATIC)
  ENDIF ()
ELSE()
  FIND_PACKAGE( LibXslt )
ENDIF ()
