{
    "name": "cxproc",
    "version": "2.0",
    "description": "configurable processor for XML-XSL.",
    "homepage": "https://github.com/raxdne/cxproc",
    "license": "GPL-3.0-only",
    "supports": "!uwp & !xbox",
    "dependencies": [
	"zlib",
	"libzip",
	"liblzma",
	"libarchive",
	"pcre2",
	{
	    "name": "libxml2",
	    "default-features": true
	},
	{
	    "name": "libxslt",
	    "default-features": true
	},
	{
	    "name": "curl",
	    "default-features": true
	},
	"sqlite3",
	"duktape",
	{
	    "name": "cmark",
	    "default-features": true
	},
	{
	    "name": "vcpkg-cmake",
	    "host": true
	},
	{
	    "name": "vcpkg-cmake-config",
	    "host": true
	}
    ],
    "features": {
	"tools": {
	    "description": "Build the utilities"
	}
    }
}
